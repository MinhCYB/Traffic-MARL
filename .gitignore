# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Môi trường ────────────────────────────────────────────────────────────────
.env
venv/
.venv/
env/
*.conda
