<?xml version="1.0" encoding="UTF-8"?>
<!--
    E2 (area) detectors — 200m mỗi lane, đặt trước ngã tư
    Đo: occupancy, meanSpeed, jamLengthVehicle, nVehSeen
    freq=5 khớp với delta_time của RL agent

    Naming: e2_<edge_id>_<lane_index>
    Lane index: 0 = lane phải, 1 = lane trái
-->
<additional>

    <!-- ════════════ VÀO N01 ════════════ -->
    <!-- từ NT_N_W (bắc) -->
    <laneAreaDetector id="e2_NT_N_W_N01_0" lane="NT_N_W_N01_0" pos="-1" length="180" freq="5" file="NUL"/>
    <laneAreaDetector id="e2_NT_N_W_N01_1" lane="NT_N_W_N01_1" pos="-1" length="180" freq="5" file="NUL"/>
    <!-- từ NT_W_N (tây) -->
    <laneAreaDetector id="e2_NT_W_N_N01_0" lane="NT_W_N_N01_0" pos="-1" length="180" freq="5" file="NUL"/>
    <laneAreaDetector id="e2_NT_W_N_N01_1" lane="NT_W_N_N01_1" pos="-1" length="180" freq="5" file="NUL"/>
    <!-- từ SRC1 (đông, đường chính ngang) -->
    <laneAreaDetector id="e2_SRC1_N01_0"   lane="SRC1_N01_0"   pos="-1" length="180" freq="5" file="NUL"/>
    <laneAreaDetector id="e2_SRC1_N01_1"   lane="SRC1_N01_1"   pos="-1" length="180" freq="5" file="NUL"/>
    <!-- từ SRC3 (nam, ngõ nhỏ) -->
    <laneAreaDetector id="e2_SRC3_N01_0"   lane="SRC3_N01_0"   pos="-1" length="180" freq="5" file="NUL"/>
    <laneAreaDetector id="e2_SRC3_N01_1"   lane="SRC3_N01_1"   pos="-1" length="180" freq="5" file="NUL"/>

    <!-- ════════════ VÀO N02 ════════════ -->
