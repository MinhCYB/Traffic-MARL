    <!-- từ SRC2 (tây, đường chính ngang) -->
    <laneAreaDetector id="e2_SRC2_N04_0"   lane="SRC2_N04_0"   pos="-1" length="180" freq="5" file="NUL"/>
    <laneAreaDetector id="e2_SRC2_N04_1"   lane="SRC2_N04_1"   pos="-1" length="180" freq="5" file="NUL"/>
    <!-- từ SRC4 (bắc, ngõ nhỏ) -->
    <laneAreaDetector id="e2_SRC4_N04_0"   lane="SRC4_N04_0"   pos="-1" length="180" freq="5" file="NUL"/>
    <laneAreaDetector id="e2_SRC4_N04_1"   lane="SRC4_N04_1"   pos="-1" length="180" freq="5" file="NUL"/>

</additional>