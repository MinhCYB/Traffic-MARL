    <laneAreaDetector id="e2_NT_N_E_N02_0" lane="NT_N_E_N02_0" pos="-1" length="180" freq="5" file="NUL"/>
    <laneAreaDetector id="e2_NT_N_E_N02_1" lane="NT_N_E_N02_1" pos="-1" length="180" freq="5" file="NUL"/>
    <!-- từ NT_E_N (đông) -->
    <laneAreaDetector id="e2_NT_E_N_N02_0" lane="NT_E_N_N02_0" pos="-1" length="180" freq="5" file="NUL"/>
    <laneAreaDetector id="e2_NT_E_N_N02_1" lane="NT_E_N_N02_1" pos="-1" length="180" freq="5" file="NUL"/>
    <!-- từ SRC1 (tây, đường chính ngang) -->
    <laneAreaDetector id="e2_SRC1_N02_0"   lane="SRC1_N02_0"   pos="-1" length="180" freq="5" file="NUL"/>
    <laneAreaDetector id="e2_SRC1_N02_1"   lane="SRC1_N02_1"   pos="-1" length="180" freq="5" file="NUL"/>
    <!-- từ SRC4 (nam, ngõ nhỏ) -->
    <laneAreaDetector id="e2_SRC4_N02_0"   lane="SRC4_N02_0"   pos="-1" length="180" freq="5" file="NUL"/>
    <laneAreaDetector id="e2_SRC4_N02_1"   lane="SRC4_N02_1"   pos="-1" length="180" freq="5" file="NUL"/>

    <!-- ════════════ VÀO N03 ════════════ -->
