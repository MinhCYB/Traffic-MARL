    <!-- từ SRC2 (đông, đường chính ngang) -->
    <laneAreaDetector id="e2_SRC2_N03_0"   lane="SRC2_N03_0"   pos="-1" length="180" freq="5" file="NUL"/>
    <laneAreaDetector id="e2_SRC2_N03_1"   lane="SRC2_N03_1"   pos="-1" length="180" freq="5" file="NUL"/>
    <!-- từ SRC3 (bắc, ngõ nhỏ) -->
