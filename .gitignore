# ── Checkpoints & logs ────────────────────────────────────────────────────────
# Periodic saves — không push (có thể nặng)
checkpoints/**/*.pt
# Final weights — push lên git (nhẹ, tiện theo dõi)
!checkpoints/final/*.pt
# logs/*/
# logs/merged.json
# Giữ lại cấu trúc folder
!checkpoints/.gitkeep
!logs/.gitkeep

# ── SUMO output ───────────────────────────────────────────────────────────────
simulation/net/2x2.net.xml
*.xml.bak
*.sumo.cfg.bak
tripinfo*.xml
summary*.xml

